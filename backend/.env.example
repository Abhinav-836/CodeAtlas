# CodeAtlas Configuration
# Copy this file to .env and update the values

# API Configuration
API_TITLE="CodeAtlas API"
API_VERSION="1.0.0"
API_DESCRIPTION="AI-powered code intelligence platform"
DEBUG=True

# Security
API_KEY="your-api-key-here-change-in-production"
SECRET_KEY="your-secret-key-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL="sqlite:///./codeatlas.db"
# For PostgreSQL: postgresql://user:password@localhost/codeatlas

# File Storage
UPLOAD_DIR="storage/uploads"
REPORT_DIR="storage/reports"
EXPORT_DIR="storage/exports"
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# Analysis
MAX_WORKERS=4
ANALYSIS_TIMEOUT=300  # 5 minutes in seconds

# OpenAI Integration (Optional)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4"
OPENAI_MAX_TOKENS=4000

# GitHub Integration (Optional)
GITHUB_TOKEN="ghp_..."
GITHUB_API_URL="https://api.github.com"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/codeatlas.log"

# Cache
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL=3600  # 1 hour in seconds

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Email (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@codeatlas.dev"

# Monitoring
SENTRY_DSN=""  # Optional: for error tracking
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_AI=True
ENABLE_GITHUB=True
ENABLE_PDF_EXPORT=True